# MemBrain API 镜像；使用 GHCR 自动构建产物时只需按需改 owner。
MEMBRAIN_IMAGE=ghcr.io/ai-friend-coming/membrain-api:main
COMPOSE_PROJECT_NAME=membrain

# LLM service，用于记忆抽取、query 改写和 QA reasoning。
LLM_API_URL=http://host.docker.internal:4000/v1
LLM_API_KEY=sk-1234

# PostgreSQL / ParadeDB。Compose 内部会把 API 容器的 DB_HOST 覆写成 db。
LOCAL_DATA_DIR=./database
EXPS_DIR=./evaluation/exps
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWD=MemBrain
DB_NAME=MemBrain
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600
DB_STATEMENT_TIMEOUT=300000
DB_WORKER_POOL_SIZE=1
DB_WORKER_MAX_OVERFLOW=0

# MemBrain API server。
BACKEND_MODE=demo
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9574
BACKEND_WORKERS=2
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Embedding service。可指向自部署 vLLM，也可指向 OpenAI-compatible embedding API。
EMBED_SERVICE_URL=http://host.docker.internal:9113/v1/embeddings
EMBED_API_KEY=
EMBED_MODEL=qwen3-embed
EMBED_DIM=2560

# Rerank service。strategy=rrf 时不需要；strategy=rerank 时必须可访问。
RERANK_SERVICE_URL=http://host.docker.internal:9114/v1/rerank
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank

# Fact extraction batching。
EXTRACT_BATCH_MAX_MESSAGES=10
EXTRACT_BATCH_MAX_CHARS=1500
EXTRACT_CONTEXT_TAIL_SIZE=10

# Two-pass extraction context。
EXTRACTION_CONTEXT_TOP_K=20
EXTRACTION_CONTEXT_PER_QUERY=5

# Entity resolution。
RESOLVER_CANDIDATE_TOP_K=10
RESOLVER_JACCARD_THRESHOLD=0.9
RESOLVER_ENTROPY_THRESHOLD=1.5
RESOLVER_MIN_NAME_LENGTH=6
RESOLVER_MIN_TOKEN_COUNT=2
RESOLVER_MINHASH_PERMUTATIONS=32
RESOLVER_MINHASH_BAND_SIZE=4
RESOLVER_LLM_ENABLED=true
CANONICALIZER_ENABLED=true

# Entity tree。
TREE_MAX_CHILDREN=15
TREE_MERGE_THRESHOLD=8
AUDIT_DOWN_WARMUP_MIN=5
AUDIT_MIN_UNCERTAINTY=10.0
AUDIT_MAX_K=5
DEPTH_D0=2
DEPTH_C=1.3
MIN_FRESH_FOR_PROPAGATE=3
ALPHA_DESC=0.5
W_SOFT_BASE=3
W_SOFT_LOG=1.5
W_WIDTH=3.0
W_DEPTH=5.0

# QA retrieval。
SUMMARY_SESSION_MAX_CHARS=8000
MSG_COMPRESS_THRESHOLD=4000
QA_BM25_FACT_TOP_N=20
QA_EMBED_FACT_TOP_N=20
QA_ENTITY_TOP_N=5
QA_TREE_BEAM_WIDTH=3
QA_TREE_FACT_TOP_N=20
QA_BUDGET_MAX_TOKENS=2000
QA_MAX_PER_LEAF_ASPECT=3
QA_MAX_PER_MID_ASPECT=8
QA_RERANK_TOP_K=12
QA_MULTI_QUERY_ENABLED=true
QA_SESSION_BM25_TOP_N=10
QA_SESSION_FINAL_TOP_N=5
QA_BM25_MSG_TOP_N=5
QA_LLM_MODEL=gpt-4.1-mini
QA_LLM_COT_MAX_TOKENS=1024
QA_SEARCH_POOL_SIZE=20

# PersonaMEM v2 virtual session splitting。
PERSONAMEM_VIRTUAL_SESSION_SIZE=50
