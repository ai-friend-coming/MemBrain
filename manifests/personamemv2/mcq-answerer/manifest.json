{
  "task_id": "mcq-answerer",
  "type": "agent",
  "description": "Select the best MCQ option respecting privacy, forgotten preferences, and memory evidence",
  "model": "gpt-4.1-mini",
  "temperature": 0.1,
  "max_tokens": 1024,
  "schema": "schema.py",
  "parameters": {
    "question":       {"required": true, "default": ""},
    "choice_a":       {"required": true, "default": ""},
    "choice_b":       {"required": true, "default": ""},
    "choice_c":       {"required": true, "default": ""},
    "choice_d":       {"required": true, "default": ""},
    "facts_question": {"required": true, "default": ""},
    "facts_a":        {"required": true, "default": ""},
    "facts_b":        {"required": true, "default": ""},
    "facts_c":        {"required": true, "default": ""},
    "facts_d":        {"required": true, "default": ""},
    "constraints":    {"required": false, "default": ""}
  },
  "prompts": [
    {"template": "system.md"},
    {"template": "context.md"}
  ],
  "timeout": 30
}
